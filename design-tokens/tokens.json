{
  "color": {
    "brand":       { "$value": "#c2622a", "$type": "color", "$description": "Color primario Café de Barrio" },
    "brand-hover": { "$value": "#a85220", "$type": "color" },
    "bg":          { "$value": "#f5f6fa", "$type": "color" },
    "card":        { "$value": "#ffffff", "$type": "color" },
    "text":        { "$value": "#111827", "$type": "color" },
    "muted":       { "$value": "#6b7280", "$type": "color" },
    "border":      { "$value": "#e5e7eb", "$type": "color" },
    "success":     { "$value": "#22c55e", "$type": "color" },
    "danger":      { "$value": "#ef4444", "$type": "color" },
    "warning":     { "$value": "#f59e0b", "$type": "color" },
    "sidebar":     { "$value": "#1a1a1a", "$type": "color" }
  },
  "dimension": {
    "radius":    { "$value": "10px",  "$type": "dimension" },
    "sidebar-w": { "$value": "220px", "$type": "dimension" }
  },
  "chart": {
    "palette-0": { "$value": "#c2622a", "$type": "color" },
    "palette-1": { "$value": "#4a90d9", "$type": "color" },
    "palette-2": { "$value": "#22c55e", "$type": "color" },
    "palette-3": { "$value": "#9b59b6", "$type": "color" },
    "palette-4": { "$value": "#f59e0b", "$type": "color" }
  },
  "semantic": {
    "color": {
      "action": {
        "primary":       { "$value": "{color.brand}",       "$type": "color", "$description": "Botones y CTA principales" },
        "primary-hover": { "$value": "{color.brand-hover}",  "$type": "color" }
      },
      "surface": {
        "page":    { "$value": "{color.bg}",      "$type": "color" },
        "card":    { "$value": "{color.card}",    "$type": "color" },
        "sidebar": { "$value": "{color.sidebar}", "$type": "color" }
      },
      "text": {
        "default": { "$value": "{color.text}",   "$type": "color" },
        "muted":   { "$value": "{color.muted}",  "$type": "color" }
      },
      "border": {
        "default": { "$value": "{color.border}", "$type": "color" }
      },
      "feedback": {
        "success": { "$value": "{color.success}", "$type": "color" },
        "danger":  { "$value": "{color.danger}",  "$type": "color" },
        "warning": { "$value": "{color.warning}", "$type": "color" }
      }
    }
  }
}
