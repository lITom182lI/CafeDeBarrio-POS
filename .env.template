# ============================================================
# CAFÉ DE BARRIO POS — Configuración de instalación
# ============================================================
# 1. Copia este archivo: cp .env.template .env  (o usa setup.ps1)
# 2. Rellena los valores marcados con <CAMBIAR>
# 3. NUNCA subas .env a git
# ============================================================

# --- Base de datos ---
# Contraseña para SQL Server (mín. 8 chars, mayúsculas, números y símbolo)
SA_PASSWORD=<CAMBIAR_POR_PASSWORD_SQL>

# --- Seguridad JWT ---
# Clave secreta de 64+ chars. Generada automáticamente por setup.ps1
JWT_KEY=<GENERADO_POR_SETUP>

# --- CORS ---
# URL(s) desde donde accede el Dashboard/POS (separadas por coma si hay varias)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Admin inicial ---
# Password del usuario admin@cafedebarrio.com (primera vez que arranca)
ADMIN_PASSWORD=<CAMBIAR_POR_PASSWORD_ADMIN>

# --- SUNAT / Nubefact ---
# Cambiar a true solo cuando tengas credenciales Nubefact
SUNAT_ENABLED=false
SUNAT_RUC=
SUNAT_OSE_TOKEN=
