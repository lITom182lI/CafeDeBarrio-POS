# ─────────────────────────────────────────────────────────────────────────────
#  Cafe de Barrio POS — Variables de entorno para Docker Compose
#
#  SETUP RÁPIDO (genera .env automáticamente con passwords seguros):
#    .\setup.ps1
#
#  O copia manualmente:
#    cp .env.example .env   (Linux/Mac)
#    copy .env.example .env (Windows)
#  y reemplaza cada valor CAMBIAR_POR_*
# ─────────────────────────────────────────────────────────────────────────────

# Contraseña del usuario SA de SQL Server en Docker
# Requisitos: mín. 12 chars, mayúscula + minúscula + número + especial
SA_PASSWORD=CAMBIAR_POR_PASSWORD_SQL_SEGURO

# Clave secreta JWT — mínimo 32 caracteres
JWT_KEY=CAMBIAR_POR_SECRETO_JWT_MINIMO_32_CARACTERES

# Orígenes CORS permitidos (separados por coma, sin espacios)
# Local:      http://localhost:5173,http://localhost:5174
# Producción: https://pos.tudominio.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Contraseña inicial del usuario admin del dashboard
ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_ADMIN

# SUNAT — mantener false hasta tener credenciales reales del OSE
SUNAT_ENABLED=false
SUNAT_RUC=
SUNAT_OSE_TOKEN=
