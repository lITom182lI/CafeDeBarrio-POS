# ─── JWT (generar con: scripts/generate-jwt-secret.ps1) ──────────────────────
Jwt__Key=REEMPLAZAR_CON_SECRETO_MINIMO_64_CHARS_BASE64

# ─── Admin seed ──────────────────────────────────────────────────────────────
Seed__AdminPassword=CONTRASEÑA_SEGURA_AQUI

# ─── Conexión DB ──────────────────────────────────────────────────────────────
# Dev local (Windows Auth):
ConnectionStrings__DefaultConnection=Server=localhost,1434;Database=CafeDeBarrio;Integrated Security=True;TrustServerCertificate=True;
# Producción (SQL Auth):
# ConnectionStrings__DefaultConnection=Server=127.0.0.1,14333;Database=CafeDeBarrio;User Id=sa;Password=DevLocal123!;TrustServerCertificate=True;

# ─── SUNAT / OSE (obtener del proveedor OSE al contratar) ────────────────────
Sunat__Enabled=false
Sunat__Ruc=20XXXXXXXXX
Sunat__OseToken=TOKEN_DEL_OSE_AQUI

# ─── CORS ────────────────────────────────────────────────────────────────────
Cors__AllowedOrigin=https://tu-dominio.com
