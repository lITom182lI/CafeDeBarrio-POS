# ─── SQL Server (Docker local) ───────────────────────────────────────────────
MSSQL_SA_PASSWORD=your_strong_password_here

# ─── Variables de entorno de producción para CafeBarrio.API ──────────────────
# Nota: .NET lee claves anidadas con __ (doble guion bajo).
# Ejecutar scripts/generate-jwt-secret.ps1 para generar un valor seguro.
Jwt__Key=REEMPLAZAR_CON_SECRETO_MINIMO_48_CHARS_BASE64

# Cadena de conexión a SQL Server de producción
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER;Database=CafeDeBarrio;User Id=sa;Password=YOUR_PASSWORD;TrustServerCertificate=True;

# URL del dashboard en producción (puede ser múltiple separando con coma)
Cors__AllowedOrigin=https://tu-dominio.com
