              "value": "[format('Server=tcp:{0}.database.windows.net,1433;Database={1};User Id={2};Password={3};Encrypt=True;Connection Timeout=30;', format('{0}-sql', parameters('projectName')), format('{0}db', parameters('projectName')), parameters('sqlAdminLogin'), parameters('sqlAdminPassword'))]"
